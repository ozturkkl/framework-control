root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

[*.{yml,yaml,json,md}]
indent_style = space
indent_size = 2

[*.rs]
indent_style = space
indent_size = 4

[*.{js,cjs,mjs,ts,tsx,svelte,css,scss,html}]
indent_style = tab
indent_size = 4

[*.sh]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
