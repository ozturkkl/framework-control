{
  "name": "framework-control-web",
  "private": true,
  "version": "0.5.0-beta.2",
  "type": "module",
  "scripts": {
    "web:gen:api": "node scripts/gen-api.mjs",
    "web:gen:icons": "node scripts/gen-icons.mjs",
    "web:build:msi": "node scripts/build-msi.mjs",
    "web:build:linux": "node scripts/build-linux.mjs",
    "web:predev": "npm run web:gen:icons && npm run web:gen:api",
    "web:dev": "vite",
    "web:prebuild": "npm run web:gen:icons && npm run web:gen:api",
    "web:build": "vite build",
    "web:preview": "vite preview",
    "web:lint:check": "eslint --ext .ts,.svelte src",
    "web:format": "prettier --write .",
    "web:format:check": "prettier --check .",
    "service:fmt:check": "cd ../service && cargo fmt --all -- --check",
    "service:fmt": "cd ../service && cargo fmt --all",
    "lint": "npm run web:lint:check && npm run web:format:check && npm run service:fmt:check",
    "format": "npm run web:format && npm run service:fmt",
    "postinstall": "npm run web:gen:icons && npm run web:gen:api",
    "clean": "rimraf dist .vite .svelte-kit openapi.json src/api"
  },
  "devDependencies": {
    "@iconify/svelte": "^4.1.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "autoprefixer": "^10.4.21",
    "daisyui": "^4.12.24",
    "eslint": "^9.16.0",
    "eslint-plugin-svelte": "^2.46.1",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5",
    "sharp": "^0.33.5",
    "svelte": "^4.2.0",
    "svelte-eslint-parser": "^0.41.0",
    "tailwindcss": "^3.4.17",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "openapi-typescript-codegen": "^0.29.0"
  }
}
