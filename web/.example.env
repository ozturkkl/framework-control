# Framework Control – web UI environment variables
# Copy this file to `.env.local` (framework-control/web/.env.local) and adjust as needed.

# Local service URL (optional; auto-detects from the current origin if omitted).
# Set this to match FRAMEWORK_CONTROL_PORT in the service.
VITE_API_BASE=http://127.0.0.1:8090

# Optional: explicit base path for the built site (e.g. "/" or "/framework-control/").
# Leave unset for local dev; mainly used by CI / GitHub Pages builds.
# VITE_BASE=/

# Optional: set to "true" to build with the GitHub Pages base path ("/framework-control/").
# Normally only set by CI.
# GITHUB_PAGES=false
