# Framework Control – service environment variables
# Copy this file to `.env` (framework-control/service/.env) and adjust as needed.

# Required: port the service binds/listens on (valid u16, e.g. 1-65535)
FRAMEWORK_CONTROL_PORT=8090

# Allowed CORS origins for the UI (comma-separated).
# Must be present, but may be left empty to allow only same-origin requests.
FRAMEWORK_CONTROL_ALLOWED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174,https://ozturkkl.github.io

# GitHub repo used by the update endpoints (owner/name, or a full github.com URL).
# Must be present for builds, but may be left empty to disable the update feature.
FRAMEWORK_CONTROL_UPDATE_REPO=ozturkkl/framework-control

# Optional: override the path to the service config file.
# Defaults: Windows -> %PROGRAMDATA%\FrameworkControl\config.json
# Uncomment to use a custom location.
# FRAMEWORK_CONTROL_CONFIG=C:\ProgramData\FrameworkControl\config.json
